# Application environment:
# development | test | staging | production
NODE_ENV=development

# Local development binds only to this machine.
# Containers commonly use 0.0.0.0.
HOST=127.0.0.1

PORT=4000

# Produces routes such as /v1/products.
API_PREFIX=v1

# Exact browser origin allowed by CORS.
FRONTEND_ORIGIN=http://localhost:3000

LOG_LEVEL=debug

# Local PostgreSQL ports 5432 and 5433 are reserved for JO.DIAMONDS Docker databases.
DATABASE_URL=postgres://jdiamonds:jdiamonds@127.0.0.1:5432/jdiamonds_dev
TEST_DATABASE_URL=postgres://jdiamonds:jdiamonds@127.0.0.1:5433/jdiamonds_test